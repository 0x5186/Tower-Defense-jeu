<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="universite_paris8.iut.nchaieb.sae_jeux.Controller">
   <center>
      <StackPane fx:id="stackPane" prefHeight="150.0" prefWidth="200.0">
         <ImageView fitHeight="600" fitWidth="800" preserveRatio="false">
            <image>
               <Image url="@images/menutest.png" />
            </image>
         </ImageView>
         <TilePane fx:id="tilePane" alignment="CENTER" prefHeight="200.0" prefRows="25" prefTileHeight="32.0" prefTileWidth="32.0" prefWidth="200.0" BorderPane.alignment="CENTER">

         </TilePane>
         <Button fx:id="boutonJouer" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#onBoutonJouerClique" prefHeight="59.0" prefWidth="293.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;">
            <graphic>
               <ImageView fitHeight="295.0" fitWidth="300.0" pickOnBounds="false" preserveRatio="true">
               <image>
                     <Image url="@images/boutonJouer.png" />
                  </image>
               </ImageView>
            </graphic>
         </Button>
      </StackPane>
   </center>
</BorderPane>
