<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="1080" prefWidth="1920" style="-fx-background-color: #1a1a1a;" xmlns="http://javafx.com/javafx/8.0.40" xmlns:fx="http://javafx.com/fxml/1" fx:controller="universite_paris8.iut.nchaieb.sae_jeux.Controller">
   <center>
      <StackPane fx:id="stackPane" alignment="TOP_LEFT">
         <TilePane fx:id="tilePane" alignment="TOP_LEFT" prefColumns="120" prefRows="52" prefTileHeight="16" prefTileWidth="16" BorderPane.alignment="TOP_LEFT">
         </TilePane>

         <Button fx:id="symboleCroix" layoutX="500" layoutY="200" mnemonicParsing="false" onAction="#AppuyerSurSymboleCroix" prefHeight="7.0" prefWidth="2.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;">
            <graphic>
               <ImageView fitHeight="64.0" fitWidth="64.0" preserveRatio="true">
                  <image>
                     <Image url="@images/symboleCroix.png" />
                  </image>
               </ImageView>
            </graphic>
         </Button>
         <Button fx:id="symboleGoutteDeau" layoutX="500" layoutY="200" mnemonicParsing="false" onAction="#AppuyerSurSymboleGoutteDeau" prefHeight="7.0" prefWidth="2.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;">
            <graphic>
               <ImageView fitHeight="64.0" fitWidth="64.0" nodeOrientation="INHERIT" preserveRatio="true">
                  <image>
                     <Image url="@images/symboleCroix.png" />
                  </image>
               </ImageView>
            </graphic>
         </Button>
      </StackPane>
   </center>

   <bottom>
      <StackPane prefHeight="248.0" prefWidth="1920.0" BorderPane.alignment="CENTER">
         <children>
            <ImageView fitHeight="248.0" fitWidth="1920.0" preserveRatio="false">
               <image>
                  <Image url="@images/interfaceBas.png" />
               </image>
            </ImageView>

            <Pane prefHeight="248.0" prefWidth="1920.0">
               <children>
                  <ImageView fitHeight="200.0" fitWidth="300.0" layoutX="1550.0" layoutY="20.0" preserveRatio="true">
                     <image>
                        <Image url="@images/FeuillePourLesSorts.png" />
                     </image>
                  </ImageView>

                  <Button fx:id="boutonMonstreEnnemi" layoutX="100.0" layoutY="95.0" prefHeight="50.0" prefWidth="150.0" style="-fx-font-size: 16px;" mnemonicParsing="false" onAction="#AjouterMonstreEnnemi" text="Ajouter ennemi" />
                  <Button fx:id="boutonAjouterMonstre" layoutX="300.0" layoutY="95.0" prefHeight="50.0" prefWidth="150.0" style="-fx-font-size: 16px;" mnemonicParsing="false" onAction="#AjouterMonstreAllie" text="Ajouter allié" />
                  <Button fx:id="boutonAjouterTour" layoutX="500.0" layoutY="95.0" prefHeight="50.0" prefWidth="150.0" style="-fx-font-size: 16px;" mnemonicParsing="false" onAction="#activerModePlacementTour" text="Ajouter tour" />
               </children>
            </Pane>
         </children>
      </StackPane>
   </bottom>
</BorderPane>